{
  "name": "cadtool-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "displayName": "CadToolOnline",
  "description": "Online CAD tool for multi-body dynamics design",
  "publisher": "cadtool",
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "cadtool-online.openEditor",
        "title": "Open CAD Editor",
        "category": "CadToolOnline"
      }
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.cjs --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
    "build:webview": "vite build",
    "build:all": "pnpm build:wasm && pnpm build && pnpm build:extension && pnpm build:webview",
    "dev": "pnpm -r --parallel dev",
    "dev:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.cjs --external:vscode --format=cjs --platform=node --target=node18 --sourcemap --watch",
    "lint": "eslint packages src --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\" \"src/**/*.{ts,tsx}\"",
    "clean": "pnpm -r clean && rimraf dist",
    "setup:wasm": "node scripts/setup_wasm_deps.mjs",
    "build:wasm": "cd packages/geo/cpp && cmake --preset release && cmake --build --preset release",
    "build:wasm:debug": "cd packages/geo/cpp && cmake --preset debug && cmake --build --preset debug",
    "vscode:prepublish": "pnpm run build:all",
    "package": "pnpm run build:all && vsce package --no-dependencies"
  },
  "dependencies": {
    "@cadtool-online/core": "workspace:*",
    "@cadtool-online/geo": "workspace:*",
    "@cadtool-online/three": "workspace:*",
    "@cadtool-online/ui": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0"
  }
}
