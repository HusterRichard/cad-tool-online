{
  "name": "cadtool-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Online CAD tool for multi-body dynamics design",
  "scripts": {
    "build": "pnpm -r build",
    "build:all": "pnpm build:wasm && pnpm build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "clean": "pnpm -r clean",
    "setup:wasm": "node scripts/setup_wasm_deps.mjs",
    "build:wasm": "cd packages/geo/cpp && cmake --preset release && cmake --build --preset release",
    "build:wasm:debug": "cd packages/geo/cpp && cmake --preset debug && cmake --build --preset debug"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
