# Exclude source packages
packages/**

# Exclude source files
src/**
*.ts
!*.d.ts
tsconfig.json
tsconfig.extension.json

# Exclude build config
vite.config.ts

# Exclude dev dependencies
node_modules/**

# Exclude test files
**/*.spec.ts
**/*.test.ts

# Exclude git
.git/**
.gitignore

# Exclude dev/CI files
.claude/**
.vscode/**
scripts/**
pnpm-workspace.yaml
pnpm-lock.yaml

# Exclude dist by default, then include runtime artifacts only
dist/**
!dist/extension.cjs
!dist/webview/webview.js
!dist/wasm/**
dist/wasm/*.d.ts

# Exclude unnecessary files
*.map
.eslintrc*
.prettierrc*
.VSCodeCounter/**
ref/**
view-result/**
ai-artifacts/**
docs/**
report/**
tests/**
data/**
demo/**
prompts/**
*.pen
*.vsix
cad-ui-err.png
plan.md
TASK.md
CLAUDE.md
.project-structure.md
.mcp.json
.env.example
public/**
!public/icons/png/32/**
