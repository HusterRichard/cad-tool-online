# Exclude source packages
packages/**

# Exclude source files
src/**
*.ts
!*.d.ts
tsconfig.json
tsconfig.extension.json

# Exclude build config
vite.config.ts

# Exclude dev dependencies
node_modules/**

# Exclude test files
**/*.spec.ts
**/*.test.ts

# Exclude git
.git/**
.gitignore

# Exclude dev/CI files
.claude/**
.vscode/**
scripts/**
pnpm-workspace.yaml
pnpm-lock.yaml

# Include dist folder (extension + webview + wasm)
!dist/**

# Exclude unnecessary files
*.map
.eslintrc*
.prettierrc*
