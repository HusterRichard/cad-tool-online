# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========================================
# 项目配置
# ========================================

# 项目名称
PROJECT_NAME=CadToolOnline

# 开发模式 (development | production)
NODE_ENV=development

# ========================================
# VSCode 插件配置
# ========================================

# 插件日志级别 (debug | info | warn | error)
LOG_LEVEL=info

# 是否启用调试模式
DEBUG_MODE=true

# ========================================
# WASM 配置
# ========================================

# WASM 模块路径（相对于 packages/geo）
# WASM_MODULE_PATH=./wasm/cad-geo.wasm

# WASM 初始化超时时间（毫秒）
WASM_INIT_TIMEOUT=5000

# ========================================
# 文件处理配置
# ========================================

# STEP 文件最大大小（MB）
MAX_STEP_FILE_SIZE=100

# 网格生成参数
MESH_LINEAR_DEFLECTION=0.1
MESH_ANGULAR_DEFLECTION=0.5

# ========================================
# 渲染配置
# ========================================

# 默认相机位置
CAMERA_DEFAULT_POSITION_X=5
CAMERA_DEFAULT_POSITION_Y=5
CAMERA_DEFAULT_POSITION_Z=5

# 渲染帧率限制
MAX_FPS=60

# 抗锯齿
ENABLE_ANTIALIASING=true

# ========================================
# API 配置（如有远程服务）
# ========================================

# API 基础 URL（留空表示无远程服务）
# API_BASE_URL=

# API 超时时间（毫秒）
# API_TIMEOUT=30000

# ========================================
# 性能配置
# ========================================

# 是否启用性能监控
ENABLE_PERFORMANCE_MONITORING=false

# 内存限制（MB）
MEMORY_LIMIT=512

# ========================================
# 测试配置
# ========================================

# 测试超时时间（毫秒）
TEST_TIMEOUT=10000

# 测试覆盖率阈值
TEST_COVERAGE_THRESHOLD=80

# ========================================
# 安全配置
# ========================================

# 内容安全策略（CSP）
# CSP_DIRECTIVES=default-src 'self'

# 是否允许加载外部资源
ALLOW_EXTERNAL_RESOURCES=false

# ========================================
# 开发者选项
# ========================================

# 是否显示 FPS 统计
SHOW_FPS_STATS=false

# 是否启用热重载
HOT_RELOAD=true

# 源码映射
ENABLE_SOURCE_MAPS=true

# ========================================
# 注意事项
# ========================================
# 1. 请勿将 .env 文件提交到版本控制系统
# 2. .env 文件已在 .gitignore 中排除
# 3. 敏感信息（API 密钥等）请存放在用户级配置中
# 4. 生产环境需要覆盖相应的配置项
