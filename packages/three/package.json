{
  "name": "@cadtool-online/three",
  "version": "0.1.0",
  "private": true,
  "description": "Three.js rendering module for CadToolOnline",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "node ../core/node_modules/vitest/vitest.mjs",
    "test:run": "node ../core/node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "@cadtool-online/core": "workspace:*",
    "@cadtool-online/geo": "workspace:*",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0"
  }
}
