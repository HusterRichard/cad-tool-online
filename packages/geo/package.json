{
  "name": "@cadtool-online/geo",
  "version": "0.1.0",
  "private": true,
  "description": "Geometry computation module with OCCT WASM",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
