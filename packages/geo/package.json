  "dependencies": {
    "@cadtool-online/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "rimraf": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
